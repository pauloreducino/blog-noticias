# ══════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — São Luís em Foco
# Copie este arquivo para .env.local e preencha
# ══════════════════════════════════════════════════

# WordPress CMS (Pantheon.io ou localhost)
# Ex.: https://live-meu-site.pantheonsite.io/wp-json/wp/v2
WORDPRESS_API_URL=http://localhost/wp-json/wp/v2

# Chave secreta para o webhook de revalidação ISR
# Gere com: openssl rand -hex 32
REVALIDATE_SECRET=sua_chave_secreta_aqui

# URL pública do site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=São Luís em Foco
NEXT_PUBLIC_SITE_DESCRIPTION=O portal de notícias de São Luís e do Maranhão

# OpenWeather API — previsão do tempo (plano gratuito)
# Crie sua chave em: https://home.openweathermap.org/api_keys
NEXT_PUBLIC_OPENWEATHER_API_KEY=sua_chave_aqui

# Google Analytics 4 (opcional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Disqus para comentários (opcional)
NEXT_PUBLIC_DISQUS_SHORTNAME=saoluisemfoco
